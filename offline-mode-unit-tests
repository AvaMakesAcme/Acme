// sync-operations.test.js

describe('Sync Operations Tests', () => {
  beforeEach(() => {
    // Clear local storage and mock network state
    localStorage.clear();
    mockNetworkStatus = 'online';
  });

  test('should queue operations when offline', async () => {
    mockNetworkStatus = 'offline';
    const operation = { type: 'update', data: { id: 1, content: 'test' }};
    await syncManager.addOperation(operation);
    expect(syncManager.pendingOperations).toContain(operation);
  });

  test('should process queue when coming online', async () => {
    // Setup pending operations
    const operations = [
      { type: 'create', data: { id: 1 }},
      { type: 'update', data: { id: 1, content: 'updated' }}
    ];
    syncManager.pendingOperations = operations;
    
    mockNetworkStatus = 'online';
    await syncManager.processQueue();
    expect(syncManager.pendingOperations).toHaveLength(0);
  });

  test('should handle conflict resolution', async () => {
    const localData = { id: 1, content: 'local', timestamp: Date.now() };
    const serverData = { id: 1, content: 'server', timestamp: Date.now() + 1000 };
    
    const resolvedData = await syncManager.resolveConflict(localData, serverData);
    expect(resolvedData).toEqual(serverData); // Last-write-wins strategy
  });

  test('should update sync timestamp after successful sync', async () => {
    const initialTimestamp = syncManager.lastSyncTimestamp;
    await syncManager.sync();
    expect(syncManager.lastSyncTimestamp).toBeGreaterThan(initialTimestamp);
  });

  test('should retry failed operations', async () => {
    mockNetworkStatus = 'unstable';
    const operation = { type: 'update', data: { id: 1 }};
    
    await syncManager.addOperation(operation);
    const retryAttempts = await syncManager.processQueue();
    expect(retryAttempts).toBeLessThanOrEqual(3);
  });
});
